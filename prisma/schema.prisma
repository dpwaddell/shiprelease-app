generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                           String                  @id @default(cuid())
  domain                       String                  @unique
  accessToken                  String                  @map("access_token")
  scope                        String
  installedAt                  DateTime                @default(now()) @map("installed_at")
  uninstalledAt                DateTime?               @map("uninstalled_at")
  planName                     String                  @default("unknown") @map("plan_name")
  planStatus                   String                  @default("inactive") @map("plan_status")
  trialEndsAt                  DateTime?               @map("trial_ends_at")
  managedPricingSubscriptionId String?                 @map("managed_pricing_subscription_id")
  createdAt                    DateTime                @default(now()) @map("created_at")
  updatedAt                    DateTime                @updatedAt @map("updated_at")
  automationSettings           AutomationSetting?
  shipstationCredentials       ShipStationCredential?
  releaseEvents                ReleaseEvent[]
  releaseJobs                  ReleaseJob[]
  usageCounters                UsageCounter[]
  appEvents                    AppEvent[]

  @@map("shops")
}

model ShipStationCredential {
  id                String    @id @default(cuid())
  shopId            String    @unique @map("shop_id")
  encryptedApiKey   String    @map("encrypted_api_key")
  encryptedApiSecret String   @map("encrypted_api_secret")
  connectionStatus  String    @default("untested") @map("connection_status")
  lastCheckedAt     DateTime? @map("last_checked_at")
  lastSuccessAt     DateTime? @map("last_success_at")
  lastFailureReason String?   @map("last_failure_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shipstation_credentials")
}

model AutomationSetting {
  id                  String   @id @default(cuid())
  shopId              String   @unique @map("shop_id")
  enabled             Boolean  @default(false)
  financialStatuses   Json     @default("[\"pending\",\"unpaid\"]") @map("financial_statuses")
  paymentMethods      Json     @default("[\"Bank Deposit\",\"Purchase Order\",\"COD\",\"Net Terms\",\"Manual Payment\"]") @map("payment_methods")
  includeTags         Json     @default("[]") @map("include_tags")
  excludeTags         Json     @default("[\"sampleguard:hold\",\"fraud\",\"review\"]") @map("exclude_tags")
  releaseDelayMinutes Int      @default(0) @map("release_delay_minutes")
  releaseOnlyFullyPaid Boolean @default(false) @map("release_only_fully_paid")
  delayMinutes        Int      @default(0) @map("delay_minutes")
  ignoreHighRiskOrders Boolean @default(true) @map("ignore_high_risk_orders")
  requireManualReviewAboveAmount Boolean @default(false) @map("require_manual_review_above_amount")
  manualReviewAmount  Decimal  @default(0) @map("manual_review_amount") @db.Decimal(12, 2)
  notificationEmail   String?  @map("notification_email")
  automationPaused    Boolean  @default(false) @map("automation_paused")
  automationPausedAt  DateTime? @map("automation_paused_at")
  lastWebhookReceivedAt DateTime? @map("last_webhook_received_at")
  notifyAutomationPaused Boolean @default(true) @map("notify_automation_paused")
  notifyReconciliationFixes Boolean @default(true) @map("notify_reconciliation_fixes")
  notifyRepeatedFailures Boolean @default(true) @map("notify_repeated_failures")
  notifyWebhookFailures Boolean @default(true) @map("notify_webhook_failures")
  repeatedFailureThreshold Int @default(3) @map("repeated_failure_threshold")
  notificationDebounceMinutes Int @default(60) @map("notification_debounce_minutes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("automation_settings")
}

model ReleaseEvent {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  orderId   String   @map("order_id")
  orderName String?  @map("order_name")
  eventType String   @map("event_type")
  status    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([shopId, eventType])
  @@map("release_events")
}

model ReleaseJob {
  id                     String    @id @default(cuid())
  shopId                 String    @map("shop_id")
  shopifyOrderId         String    @map("shopify_order_id")
  shopifyOrderName       String?   @map("shopify_order_name")
  shopifyFinancialStatus String?   @map("shopify_financial_status")
  shopifyGateway         String?   @map("shopify_gateway")
  shipstationOrderId     String?   @map("shipstation_order_id")
  idempotencyKey         String    @unique @map("idempotency_key")
  status                 String
  skipReason             String?   @map("skip_reason")
  failureReason          String?   @map("failure_reason")
  attempts               Int       @default(0)
  source                 String    @default("webhook")
  retryOfJobId           String?   @map("retry_of_job_id")
  ruleEvaluation         Json?     @map("rule_evaluation")
  decisionReason         String?   @map("decision_reason")
  lookupCandidates       Json?     @map("lookup_candidates")
  manualRetryCount       Int       @default(0) @map("manual_retry_count")
  queuedAt               DateTime  @default(now()) @map("queued_at")
  releasedAt             DateTime? @map("released_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  shop                   Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([shopId, shopifyOrderId])
  @@map("release_jobs")
}

model UsageCounter {
  id               String    @id @default(cuid())
  shopId           String    @map("shop_id")
  billingMonth     String    @map("billing_month")
  releaseCount     Int       @default(0) @map("release_count")
  warning80SentAt  DateTime? @map("warning_80_sent_at")
  warning100SentAt DateTime? @map("warning_100_sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  shop             Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, billingMonth])
  @@map("usage_counters")
}

model AppEvent {
  id        String   @id @default(cuid())
  shopId    String?  @map("shop_id")
  eventType String   @map("event_type")
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId, createdAt])
  @@map("app_events")
}
